[Unit]
Description=Edgevest Trade Server (gunicorn)
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/edgevest
EnvironmentFile=/home/ubuntu/edgevest/.env
ExecStart=/home/ubuntu/edgevest/venv/bin/gunicorn trade_server:app -c gunicorn.conf.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
