# Flask
SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_hex(32))">
FLASK_ENV=production

# Google OAuth — add https://edgevest.in/auth/callback in Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Leave empty in prod — Flask serves the React build directly (same origin, no CORS needed)
FRONTEND_URL=
CORS_ORIGINS=

# Upstox — refresh daily or use Analytics token (1-year)
UPSTOX_ACCESS_TOKEN=
