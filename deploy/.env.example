# Flask
SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_hex(32))">
FLASK_ENV=production

# Google OAuth — add https://edgevest.in/auth/callback in Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend is served from S3/CloudFront — set both to the frontend domain
FRONTEND_URL=https://edgevest.in
CORS_ORIGINS=https://edgevest.in,https://www.edgevest.in

# Upstox — refresh daily or use Analytics token (1-year)
UPSTOX_ACCESS_TOKEN=
